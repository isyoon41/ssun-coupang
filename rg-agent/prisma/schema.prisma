// 로컬 개발 편의를 위해 기본 provider 는 sqlite 로 설정한다.
// 운영 배포 시 provider 를 "postgresql" 로 변경하고 DATABASE_URL 을 교체하면 된다.
// (스키마 자체는 PostgreSQL 호환을 전제로 설계되어 있다.)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  source_added
  analyzing
  analysis_done
  risk_review
  content_drafted
  user_review
  revision_requested
  approved
  listing_pack_ready
  listed
  inbound_ready
  inbound_sent
  live
  ad_testing
  scale
  hold
  discarded
}

enum OutputStatus {
  draft
  approved
  revision_requested
  rejected
  locked
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum RecommendationGrade {
  A
  B
  C
  D
  E
}

enum SourcePlatform {
  domeme
  coupang
  smartstore
  taobao
  alpha1688
  manual
  other
}

enum AgentType {
  intake
  product_analysis
  risk
  market_strategy
  seo
  creative
  pricing
  rocketgrowth_ops
  ad_strategy
  qa
  packager
}

model User {
  id                  String           @id @default(cuid())
  email               String           @unique
  name                String?
  businessName        String?
  defaultMarginRate   Float            @default(40)
  defaultAdBudget     Int              @default(10000)
  defaultInboundQty   Int              @default(10)
  preferredCategories String?
  excludedCategories  String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  projects            ProductProject[]
}

model ProductProject {
  id                  String                @id @default(cuid())
  userId              String?
  user                User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  title               String
  sourceUrl           String?
  sourcePlatform      SourcePlatform        @default(manual)
  rawProductName      String?
  rawDescription      String?
  categoryHint        String?
  categoryCandidate   String?
  status              ProjectStatus         @default(draft)
  recommendationGrade RecommendationGrade?
  recommendationScore Float?
  riskLevel           RiskLevel?
  expectedMarginRate  Float?
  recommendedPrice    Int?
  supplyPrice         Int?
  domesticShippingCost Int?
  imageUrls           String?
  memo                String?

  aiOutputs           AiOutput[]
  pricingOutputs      PricingOutput[]
  checklists          Checklist[]
  approvals           Approval[]
  listingPackages     ListingPackage[]

  createdAt           DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([userId])
  @@index([status])
  @@index([riskLevel])
}

model AiOutput {
  id            String         @id @default(cuid())
  projectId     String
  project       ProductProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  agentType     AgentType
  outputType    String
  title         String?
  outputJson    String
  outputText    String?
  modelName     String?
  promptVersion String?
  status        OutputStatus   @default(draft)
  version       Int            @default(1)

  approvals     Approval[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@index([agentType])
  @@index([status])
}

model PricingOutput {
  id                    String         @id @default(cuid())
  projectId             String
  project               ProductProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  supplyPrice           Int            @default(0)
  domesticShippingCost  Int            @default(0)
  overseasShippingCost  Int            @default(0)
  customsCost           Int            @default(0)
  packagingCost         Int            @default(0)
  otherCost             Int            @default(0)
  coupangFeeRate        Float          @default(10.8)
  fulfillmentFee        Int            @default(0)
  storageFeeEstimate    Int            @default(0)
  returnFeeEstimate     Int            @default(0)
  adCostEstimate        Int            @default(10000)
  targetMarginRate      Float          @default(40)

  recommendedPrice      Int
  minimumPrice          Int
  adSafePrice           Int
  expectedProfit        Int
  expectedMarginRate    Float
  breakevenQuantity     Int?
  recommendedInboundQty Int?
  totalInitialCost      Int?
  formulaJson           String?

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([projectId])
}

model Checklist {
  id              String         @id @default(cuid())
  projectId       String
  project         ProductProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  checklistType   String
  title           String
  items           String
  completionRate  Float          @default(0)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([projectId])
  @@index([checklistType])
}

model Approval {
  id         String        @id @default(cuid())
  projectId  String
  project    ProductProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  aiOutputId String?
  aiOutput   AiOutput?     @relation(fields: [aiOutputId], references: [id], onDelete: SetNull)

  outputType String
  status     OutputStatus
  feedback   String?
  approvedAt DateTime?

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([projectId])
  @@index([aiOutputId])
}

model ListingPackage {
  id              String         @id @default(cuid())
  projectId       String
  project         ProductProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title           String
  packageJson     String
  markdownContent String?
  htmlContent     String?
  csvContent      String?
  status          String         @default("generated")
  version         Int            @default(1)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([projectId])
}
