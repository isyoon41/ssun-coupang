# PostgreSQL 접속 문자열 (Vercel Postgres/Neon 등). Vercel에 Postgres를 연결하면
# DATABASE_URL 환경변수가 프로젝트에 자동으로 주입된다. 로컬 개발 시에도 동일한
# 접속 문자열(또는 별도 로컬/개발용 Postgres)을 여기에 넣어 사용한다.
DATABASE_URL="postgresql://user:password@localhost:5432/rg_agent"

AI_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
NEXT_PUBLIC_APP_NAME="RG Agent"
